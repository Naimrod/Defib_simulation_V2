{
    "id": "scenario_2",
    "title": "ACR défibrillation en mode DAE",
    "description": "Un patient de 62 ans en arrêt cardio-respiratoire. Le massage cardiaque externe est en cours. Utilisez le défibrillateur en mode manuel pour délivrer un choc de 150 Joules.",
    "initialState": {
        "rhythmType": "fibrillationVentriculaire",
        "heartRate": 180,
        "spo2": 0,
        "co2": 0,
        "bloodPressure": {
            "systolic": 0,
            "diastolic": 0
        },
        "respiratoryRate": 0
    },
    "steps": [
        {
            "step": 0,
            "description": "Tournez la molette verte pour passer du mode ARRÊT au mode DAE.",
            "validation": {

                    
                        "type": "stateChange",
                        "property": "displayMode",
                        "value": "DAE"
                    
                
            }
        },









        {
      "step": 1,
      "description": "Cliquez sur le bouton Valider pour placer les électrodes sur la poitrine du patient.",
      "validation": {
        "type": "event",
        "eventName": "stepValidated"
      }
    },











        {
            "step": 2,
            "description": "Attendez le résultat de l'analyse et délivrez le choc",
            "validation": {
                "type": "event",
                "eventName": "shockDelivered"
            },
            "onComplete": [
                {
                    "action": "updateState",
                    "payload": {
                        "rhythmType": "sinus",
                        "heartRate": 62,
                        "spo2": 98,
                        "co2": 40,
                        "bloodPressure": {
                            "systolic": 115,
                            "diastolic": 80
                        },
                        "respiratoryRate": 15
                    },
                    "delay": 1000
                }
            ]
        }
    ]
}